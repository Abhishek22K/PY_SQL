Show all courses where fees > 6000 (sorted descending):
SELECT * FROM Courses
WHERE fees > 6000
ORDER BY fees DESC;



Display names of students who belong to Delhi:
SELECT student_name
FROM Students
WHERE city = 'Delhi';



Show course names whose name contains 'o' at 2nd or 3rd position:
SELECT course_name
FROM Courses
WHERE course_name LIKE '_o%' OR course_name LIKE '__o%';



Display enrollment_id, student_name, course_name, enroll_date, payment_status where payment_status = 'Paid':
SELECT 
    e.enrollment_id,
    s.student_name,
    c.course_name,
    e.enroll_date,
    e.payment_status
FROM Enrollments e
JOIN Students s ON e.student_id = s.student_id
JOIN Courses c ON e.course_id = c.course_id
WHERE e.payment_status = 'Paid';


Display student name and course name for enrollments done in November or August:
SELECT s.student_name, c.course_name
FROM Enrollments e
JOIN Students s ON e.student_id = s.student_id
JOIN Courses c ON e.course_id = c.course_id
WHERE MONTH(e.enroll_date) IN (11, 8);


Show number of courses each student enrolled in, along with min and max fees (only students with >1 course):
SELECT 
    s.student_name,
    COUNT(e.course_id) AS total_courses,
    MIN(c.fees) AS min_fees,
    MAX(c.fees) AS max_fees
FROM Enrollments e
JOIN Students s ON e.student_id = s.student_id
JOIN Courses c ON e.course_id = c.course_id
GROUP BY s.student_name
HAVING COUNT(e.course_id) > 1;


Display all courses where no student has enrolled yet:
SELECT *
FROM Courses c
LEFT JOIN Enrollments e ON c.course_id = e.course_id
WHERE e.course_id IS NULL;




