SELECT * FROM Medicines
WHERE price > 50;

SELECT * FROM Prescriptions
WHERE status = 'Pending';

SELECT s.staff_name, p.prescription_id, p.status
FROM Staff s
JOIN Prescriptions p ON s.staff_id = p.staff_id;

SELECT s.staff_name, m.medicine_name
FROM Prescriptions p
JOIN Staff s ON p.staff_id = s.staff_id
JOIN Medicines m ON p.medicine_id = m.medicine_id;

SELECT staff_id, COUNT(*) AS total_prescriptions
FROM Prescriptions
GROUP BY staff_id;

SELECT category, COUNT(*) AS total
FROM Medicines
GROUP BY category;

SELECT * FROM Medicines
ORDER BY price DESC
LIMIT 1;

